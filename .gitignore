# Gohencraft .gitignore

## OS Specific
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

## IDEs and Editors
# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
bin/
obj/
*.csproj.user

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (Rider, etc)
.idea/
*.iml
*.ipr
*.iws

# Unity (if using Unity)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
*.stackdump
*.apk
*.unitypackage
*.app

# Godot (if using Godot)
.import/
export.cfg
export_presets.cfg
.mono/
data_*/

## Build Outputs
*.exe
*.dll
*.so
*.dylib
*.app
*.ipa
*.apk
*.aab

## Logs and Databases
*.log
*.sqlite
*.db

## Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

## Asset Sources (keep compiled, ignore sources)
# Uncomment if you want to ignore source files
# *.psd
# *.ai
# *.blend
# *.blend1

## Large Files / Assets
# If using Git LFS, configure appropriately
*.mp4
*.mov
*.wav
*.mp3

## Save Files (for testing)
saves/
*.sav

## Documentation builds
docs/_build/
docs/.doctrees/

## Node modules (if using any JS tools)
node_modules/
npm-debug.log*

## Python (if using any Python tools)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

## Compiled Object files
*.slo
*.lo
*.o
*.obj

## Compiled Dynamic libraries
*.so
*.dylib
*.dll

## Compiled Static libraries
*.lai
*.la
*.a
*.lib

## Executables
*.exe
*.out
*.app

## Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

## Crash logs
crash.log
error.log
